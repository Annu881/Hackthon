                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Patient Records API\",\n  \"uon\": \"uon://hospital.records/production/patient/card-001\",\n  \"type\": \"endpoint\",\n  \"domain\": \"hospital.records\",\n  \"environment\": \"production\",\n  \"sensitivity\": \"restricted\",\n  \"attributes\": { \"department\": \"cardiology\", \"pii\": \"true\" }\n}"
                        }
                    }
