        {
            "name": "2. ACCESS CHECK (Core ABAC)",
            "item": [
                {
                    "name": "✅ Allow — Analyst reads report (working hours)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const res = pm.response.json();",
                                    "pm.test('Request success', () => pm.response.to.have.status(200));",
                                    "pm.test('Has allowed field', () => pm.expect(res).to.have.property('allowed'));",
                                    "pm.test('Has matchedPolicy', () => pm.expect(res.matchedPolicy).to.exist);",
                                    "console.log('Decision:', res.allowed ? 'ALLOW' : 'DENY', '| Policy:', res.matchedPolicy, '| Latency:', res.latencyMs + 'ms');"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/access/check",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"resourceUon\": \"uon://reports/production/report/sales\",\n  \"action\": \"read\",\n  \"context\": {}\n}"
                        }
                    }
                },
                {
                    "name": "❌ Deny — Analyst deletes report",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const res = pm.response.json();",
                                    "pm.test('Decision is deny', () => pm.expect(res.allowed).to.be.false);",
                                    "console.log('Decision:', res.allowed ? 'ALLOW' : 'DENY', '| Reason:', res.reason);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/access/check",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"resourceUon\": \"uon://reports/production/report/sales\",\n  \"action\": \"delete\",\n  \"context\": {}\n}"
                        }
                    }
                },
                {
                    "name": "✅ Allow — Kafka subscribe (engineering dept)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/access/check",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"resourceUon\": \"uon://topics.kafka/production/topic/analytics-events\",\n  \"action\": \"subscribe\",\n  \"context\": {}\n}"
                        }
                    }
                },
                {
                    "name": "⏰ Time-Based — Working hours check",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const res = pm.response.json();",
                                    "const hour = new Date().getHours();",
                                    "const isWorkingHours = hour >= 9 && hour <= 18;",
                                    "console.log('Current hour:', hour, '| Working hours:', isWorkingHours);",
                                    "console.log('Decision:', res.allowed ? 'ALLOW' : 'DENY', '| Condition:', res.conditionResult);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/access/check",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"resourceUon\": \"uon://reports/production/report/sales\",\n  \"action\": \"read\",\n  \"context\": {}\n}"
                        }
                    }
                },
                {
                    "name": "🎭 Simulate — Any user access (admin only)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/access/simulate",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"actorAttributes\": {\n    \"email\": \"test@example.com\",\n    \"role\": \"seller\",\n    \"department\": \"sales\",\n    \"location\": \"usa\",\n    \"groups\": []\n  },\n  \"resourceUon\": \"uon://orders.ecommerce/production/order/IND-001\",\n  \"action\": \"read\",\n  \"context\": {}\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "3. POLICIES",
            "item": [
                {
                    "name": "Get All Policies",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "const res = pm.response.json();",
                                    "pm.test('Policies array returned', () => pm.expect(res.policies).to.be.an('array'));",
                                    "console.log('Total policies:', res.count);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/policies",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Create Policy — Time Based",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/policies",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Working Hours Only Access\",\n  \"description\": \"PRD Example 3 — Time-based restriction\",\n  \"domain\": \"reports\",\n  \"actorMatcher\": { \"type\": \"role\", \"value\": \"analyst\" },\n  \"permissions\": [{\n    \"resourceMatcher\": \"uon://reports/production/report/*\",\n    \"actions\": [\"read\"],\n    \"condition\": { \"expression\": \"env.hour >= 9 && env.hour <= 18\" },\n    \"effect\": \"allow\"\n  }],\n  \"priority\": 25,\n  \"tags\": [\"time-based\", \"prd-example3\"]\n}"
                        }
                    }
                },
                {
                    "name": "Toggle Policy Enable/Disable",
                    "request": {
                        "method": "PATCH",
                        "url": "{{base_url}}/policies/POLICY_ID_HERE/toggle",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ]
                    }
                }
            ]
        },
