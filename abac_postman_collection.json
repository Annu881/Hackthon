                                    "console.log('Total requests:', s.totalRequests, '| Allow:', s.allowed, '| Deny:', s.denied);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/dashboard/stats",
