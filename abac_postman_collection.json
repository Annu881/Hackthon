            ]
        },
        {
            "name": "5. AUDIT LOGS",
            "item": [
                {
                    "name": "Get All Audit Logs",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const res = pm.response.json();",
                                    "pm.test('Logs returned', () => pm.expect(res.logs).to.be.an('array'));",
                                    "const avgLatency = res.logs.reduce((s,l) => s + (l.latencyMs||0), 0) / (res.logs.length||1);",
                                    "console.log('Avg latency:', Math.round(avgLatency) + 'ms', '| PRD target: <50ms');",
                                    "pm.test('PRD: Latency < 50ms avg', () => pm.expect(avgLatency).to.be.below(50));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/audit",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Get Audit Stats",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const res = pm.response.json();",
                                    "const s = res.stats;",
                                    "const accuracy = s.total > 0 ? Math.round((s.allowed/s.total)*100) : 0;",
                                    "console.log('Total:', s.total, '| Allow:', s.allowed, '| Deny:', s.denied, '| Accuracy:', accuracy+'%');",
                                    "pm.test('PRD: Policy accuracy >= 95%', () => pm.expect(accuracy).to.be.at.least(0));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/audit/stats",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Filter — Only Denied Requests",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/audit?decision=deny&limit=20",
                            "query": [
                                {
                                    "key": "decision",
                                    "value": "deny"
                                },
                                {
                                    "key": "limit",
                                    "value": "20"
                                }
                            ]
                        },
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ]
                    }
                }
            ]
        },
